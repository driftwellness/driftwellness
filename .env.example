# Database
DATABASE_URL=mysql://user:password@localhost:3306/drift

# Authentication
JWT_SECRET=your-secret-key-here
VITE_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://oauth.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im
OWNER_NAME=Your Name
OWNER_OPEN_ID=your-open-id

# Storage (AWS S3)
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your-api-key

# Frontend API
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=your-frontend-api-key

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
VITE_STRIPE_STANDARD_PRICE_ID=price_standard_id
VITE_STRIPE_PREMIUM_PRICE_ID=price_premium_id
VITE_STRIPE_IMPACT_PRICE_ID=price_impact_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Analytics
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# App Configuration
VITE_APP_TITLE=Drift
VITE_APP_LOGO=/logo.svg

# Development
NODE_ENV=development
